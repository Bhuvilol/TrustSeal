# Backend (FastAPI)
# Optional override (recommended for local no-network dev):
# DATABASE_URL=sqlite:///./trustseal.db
# For Supabase IPv4 networks, use Supabase pooler URL in DATABASE_URL.
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://trust-seal-git-main-pritamprayasbehera-9760s-projects.vercel.app,https://trust-seal-tawny.vercel.app
# Optional regex for ephemeral preview domains (example: Vercel preview URLs)
# BACKEND_CORS_ORIGIN_REGEX=^https://(v0-trust-seal|trust-seal)-git-.*-pritamprayasbehera-9760s-projects\\.vercel\\.app$
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=trustseal
POSTGRES_PORT=5432
POSTGRES_SSLMODE=prefer
SQLALCHEMY_POOL_SIZE=4
SQLALCHEMY_MAX_OVERFLOW=2
SQLALCHEMY_POOL_TIMEOUT_SECONDS=15
SQLALCHEMY_POOL_RECYCLE_SECONDS=1800
SQLALCHEMY_POOL_PRE_PING=true
POSTGRES_CONNECT_TIMEOUT_SECONDS=5
SECRET_KEY=replace-with-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
WS_REQUIRE_AUTH=false
REALTIME_QUEUE_MAXSIZE=5000
TELEMETRY_PIPELINE_MODE=dual
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_TELEMETRY_STREAM=telemetry_stream
REDIS_CUSTODY_STREAM=custody_stream
REDIS_BUNDLE_READY_STREAM=bundle_ready_stream
REDIS_ANCHOR_REQUEST_STREAM=anchor_request_stream
REDIS_TELEMETRY_CONSUMER_GROUP=batch_workers
REDIS_TELEMETRY_CONSUMER_NAME=worker-1
REDIS_TELEMETRY_READ_COUNT=200
REDIS_TELEMETRY_BLOCK_MS=1000
REDIS_RETRY_MAX_ATTEMPTS=5
REDIS_RETRY_BASE_DELAY_MS=500
REDIS_RETRY_MAX_DELAY_MS=30000
REDIS_DEAD_LETTER_STREAM=telemetry_dead_letter_stream
TELEMETRY_FINALIZATION_ENABLED=false
BATCH_MIN_RECORDS=50
BATCH_MAX_WINDOW_SECONDS=300
BATCH_FORCE_ON_CUSTODY=true
CUSTODY_GATE_MAX_AGE_SECONDS=1800
INGEST_VERIFY_SIGNATURES=false
INGEST_DEVICE_AUTH_ENABLED=false
INGEST_VERIFIER_AUTH_ENABLED=false
INGEST_DEVICE_TOKENS_JSON=
INGEST_VERIFIER_TOKENS_JSON=
INGEST_DEVICE_PUBLIC_KEYS_JSON=
INGEST_VERIFIER_PUBLIC_KEYS_JSON=
INGEST_REPLAY_MAX_CLOCK_SKEW_SECONDS=300
INGEST_REPLAY_MAX_EVENT_AGE_SECONDS=86400
ARCHIVE_HOT_RETENTION_DAYS=30
ARCHIVE_COLD_RETENTION_DAYS=365
ARCHIVE_PURGE_RETENTION_DAYS=1095
ARCHIVE_ENABLE_PURGE=false
IPFS_PIN_ENABLED=false
IPFS_PIN_ENDPOINT=https://api.pinata.cloud/pinning/pinJSONToIPFS
IPFS_PIN_JWT=
